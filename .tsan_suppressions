# TSan suppressions for pool-of-threads
#
# crossbeam uses lock-free algorithms with custom synchronization protocols
# (epoch-based reclamation, lap-counter deque access). TSan cannot model
# these protocols and reports false-positive data races inside crossbeam
# internals. ASan and Loom provide complementary coverage for our code.
#
# See: https://github.com/crossbeam-rs/crossbeam/issues/589

# crossbeam-epoch: Global::collect runs on multiple threads.
# One thread frees garbage-bag nodes while another reads from the
# concurrent queue. Epoch ordering guarantees safety.
race:crossbeam_epoch::internal::Global::collect
race:crossbeam_epoch::internal::Bag
race:crossbeam_epoch::internal::Local

# crossbeam-deque: Buffer uses volatile reads/writes with lap-counter
# synchronization. Injector::steal_batch_and_pop and Stealer::steal
# can concurrently access the same deque buffer — safe via atomic CAS
# on the stealer position, which TSan cannot trace to the buffer access.
race:crossbeam_deque::deque::Buffer
